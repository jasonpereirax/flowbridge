# ── Claude / Anthropic (obrigatório para geração de código) ──────────────────
ANTHROPIC_API_KEY=
# opcional — default: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Figma (opcional — necessário para importar designs) ──────────────────────
FIGMA_ACCESS_TOKEN=
# Figma Dev Mode MCP server (servidor local do Figma desktop).
# default: http://127.0.0.1:3845/mcp — só funciona rodando localmente.
FIGMA_DEVMODE_MCP_URL=

# ── Supabase (opcional — auth/persistência; app funciona sem em modo local) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
